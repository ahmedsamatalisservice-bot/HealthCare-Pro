# HealthCare Pro Environment Configuration

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=healthcare_pro
DB_USER=root
DB_PASS=

# App Configuration
APP_NAME=HealthCare Pro
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Session Configuration
SESSION_LIFETIME=1440
SESSION_DRIVER=file

# Email Configuration (optional)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@healthcare.local

# Security
PASSWORD_HASH_ALGO=bcrypt
BCRYPT_ROUNDS=10

# Timezone
APP_TIMEZONE=UTC
