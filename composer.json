{
  "name": "healthcare-pro/healthcare-management-system",
  "description": "A comprehensive healthcare management system built with PHP 8+",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "HealthCare Pro Team",
      "email": "dev@healthcare-pro.local"
    }
  ],
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "config/config.php",
      "app/helpers/Database.php",
      "app/helpers/Auth.php",
      "app/helpers/Validator.php"
    ]
  },
  "scripts": {
    "seed": "php seed.php",
    "serve": "php -S localhost:8000 -t public",
    "test": "phpunit --colors=always"
  },
  "config": {
    "platform": {
      "php": "8.0"
    }
  }
}
